{
  "displayName": "Stream Forge API availability < 99%",
  "documentation": {
    "content": "API availability dropped below 99% over 10 minutes.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Cloud Run request success ratio",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.label.\"service_name\"=\"stream-forge-api\" AND metric.type=\"run.googleapis.com/request_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE"
          }
        ],
        "comparison": "COMPARISON_LT",
        "thresholdValue": 0.99,
        "duration": "600s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "enabled": true
}
