{
  "name": "@stream-forge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --watch --enable-source-maps dist/index.js",
    "dev:workers": "STREAM_FORGE_START_WORKERS=true node --watch --enable-source-maps dist/index.js",
    "start": "node --enable-source-maps dist/index.js",
    "test:acceptance": "npm run build -w @stream-forge/contracts && npm run build -w @stream-forge/core && npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@google-cloud/firestore": "^7.11.2",
    "@google-cloud/storage": "^7.21.0",
    "@stream-forge/contracts": "file:../../packages/contracts",
    "@stream-forge/core": "file:../../packages/core",
    "bullmq": "^5.58.5",
    "fastify": "^5.0.0",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}
